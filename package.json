{
  "name": "pixel-clip-automation",
  "version": "0.1.0",
  "description": "YouTube Shorts chat-story generator (Remotion). Render-first MVP.",
  "scripts": {
    "dev": "remotion studio",
    "render": "remotion render Short out/video.mp4",
    "render:all": "for f in clips/*.json; do n=$(basename \"$f\" .json); remotion render \"Clip-$n\" \"out/$n.mp4\"; done",
    "check": "tsc --noEmit && node --no-warnings --experimental-strip-types scripts/check.mjs",
    "thumb": "remotion still Short out/thumb.png --frame=${THUMB_FRAME:-30}",
    "meta": "node --no-warnings --experimental-strip-types scripts/meta.mjs",
    "ship": "node --no-warnings --experimental-strip-types scripts/ship.mjs",
    "gen:char": "node scripts/gen-char.mjs",
    "gen:bg": "node scripts/gen-char.mjs --scene",
    "comfy:start": "ssh snowonyx@100.80.197.8 'bash sdev/private/comfyui/comfyctl.sh start'",
    "comfy:stop": "ssh snowonyx@100.80.197.8 'bash sdev/private/comfyui/comfyctl.sh stop'",
    "comfy:restart": "ssh snowonyx@100.80.197.8 'bash sdev/private/comfyui/comfyctl.sh restart'",
    "comfy:status": "ssh snowonyx@100.80.197.8 'bash sdev/private/comfyui/comfyctl.sh status'",
    "comfy:log": "ssh snowonyx@100.80.197.8 'bash sdev/private/comfyui/comfyctl.sh log'",
    "comfy:deploy": "scp pipeline/comfyctl.sh snowonyx@100.80.197.8:sdev/private/comfyui/comfyctl.sh && ssh snowonyx@100.80.197.8 'chmod +x sdev/private/comfyui/comfyctl.sh'",
    "quantize": "node scripts/quantize.mjs",
    "cutout": "node scripts/cutout.mjs"
  },
  "dependencies": {
    "@remotion/cli": "^4.0.0",
    "@remotion/transitions": "^4.0.482",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "remotion": "^4.0.0",
    "sharp": "^0.35.2",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.4.0"
  }
}
